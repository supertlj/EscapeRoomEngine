            }
          ]
        },
        {
          "type": "tap",
          "requiredFlags": [],
          "requiredItem": null,
          "actions": [
            {
              "type": "showMessage",
              "params": {
                "message": "A ventilated fume hood for safe chemical reactions. There are some residual chemicals inside."
              }
            }
          ]
        }
