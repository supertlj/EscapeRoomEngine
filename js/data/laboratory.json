      "shape": "rect",
      "bounds": {
        "x": 530,
        "y": 280,
        "w": 120,
        "h": 100
      },
      "appearance": {
        "fill": "#777",
        "stroke": "#888",
        "image": "data:image/svg+xml;base64,"
      },
      "zIndex": 1,
      "visible": true,
