  "puzzles": [
    {
      "id": "puzzle_computer",
      "type": "combination",
      "hotspotId": "hs_computer",
      "prompt": "Enter the 4-digit access code:",
      "solution": "3750",
      "onSolve": [
        {
          "type": "setFlag",
          "params": {
            "flag": "computer_unlocked",
            "value": true
          }
        },
        {
          "type": "showMessage",
          "params": {
            "message": "ACCESS GRANTED. The screen reads: 'Cabinet lock released. Emergency exit protocol activated.'"
          }
        }
      ],
      "onFail": [
        {
          "type": "showMessage",
          "params": {
            "message": "ACCESS DENIED. Incorrect code."
          }
        }
      ]
    }
  ],
  "hints": [
    "Check the whiteboard for clues.",
    "Look behind the chemical bottles on the shelf.",
    "Put the slide in the microscope to read the code.",
    "The code is 3750. Enter it in the computer.",
    "Use the catalyst from the cabinet in the fume hood, then use the keycard on the exit."
  ],
  "onEnter": [
    {
      "type": "showMessage",
      "params": {
        "message": "The laboratory door locks behind you with a click. A red light blinks on the exit. Find a way out!"
      }
    }
  ]
